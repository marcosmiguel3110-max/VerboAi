MONGODB_DB_NAME=biblia_ai
EMAIL_USER=tu_correo_gmail@gmail.com
EMAIL_APP_PASSWORD=tu_contraseña_de_aplicación_de_gmail
RESEND_API_KEY=re_xxxxxxxxxxxxxx
APP_USER=admin
APP_PASS=tu_contraseña_segura
AUTH_SECRET=tu_secreto_aleatorio_largo
# Correos que pueden entrar a la seccion "Clave API" de Settings (separados por coma).
# El admin local siempre tiene acceso aunque no este aca.
EMAILS_AUTORIZADOS_API=marcos.miguel.3110@gmail.com

# Emails con permiso de administrador (crear codigos, ver Verbo Code, usar NewserPro/Admin,
# y gestionar el panel de administradores). Por defecto usa los mismos que EMAILS_AUTORIZADOS_API.
# IMPORTANTE: esto es solo el punto de partida. Desde la version con panel de admin, los admins
# que se agreguen/quiten desde la web (seccion "Administradores" dentro de Codes) se guardan en
# memory/admins.json y NO hace falta tocar esta variable ni redeployar para que tomen efecto.
# ADMIN_EMAILS=marcos.miguel.3110@gmail.com

# ============================================================
# Rate limiting de imagenes (Pollinations)
# ============================================================
# Cuantos pedidos de imagen puede tener este server en simultaneo contra Pollinations. El anonimo
# (sin token) tiene un limite bastante mas estricto que nuestras otras colas internas; si segui
# viendo 429 en cadena, bajalo a 1. Default: 3 (aumentado con optimizaciones de reintentos)
# POLLINATIONS_CONCURRENCY=3

# Token OPCIONAL para las llamadas de IMAGEN (no confundir con POLLINATIONS_TEXT_API_TOKEN, que es
# para texto). Registrarse gratis en https://enter.pollinations.ai da un tier de rate limit mas alto
# que el anonimo. Si no se define, se reusa POLLINATIONS_TEXT_API_TOKEN (si existe).
# POLLINATIONS_IMAGE_API_TOKEN=

# Google Custom Search API key para la herramienta [[WEB::...]] de NewserAdvanced.
# Sin esto, la busqueda web no funciona (devuelve error). Los 5 CSE IDs ya estan
# harcodeados en server.js (rotacion automatica si uno se queda sin cuota).
GOOGLE_CSE_API_KEY=tu_api_key_de_google_custom_search

# Los modelos de texto/razonamiento/vision de cada tier (NewserLite, NewserAdvanced,
# NewserAdvanced1.5, NewserPro, NewserAdmin) ya NO se configuran por variable de
# entorno: son cascadas fijas de modelos gratis de OpenRouter, definidas en
# MODELOS_DISPONIBLES dentro de server.js (modelosOpenRouterTexto/Vision/Razonamiento).
# Para cambiar que modelos usa un tier, editá esa lista directamente en server.js.

# ============================================================
# NewserPro (modelo exclusivo para cuentas administrador)
# ============================================================
# Se habilita solo si el usuario logueado es admin (local:APP_USER o su email
# esta en ADMIN_EMAILS). Tiene el mismo feature set que NewserAdvanced1.5
# (razonamiento previo, CODE, APIDATA, WEB, INVESTIGAR con busqueda web adicional)
# y genera imagenes en alta calidad con el mismo tamaño que NewserAdvanced1.5.

# Config de Pollinations para la generacion de imagenes de NewserPro.
# Defaults: flux-realism, 1536x1536 (mismo tamaño que NewserAdvanced1.5), enhance=true
# POLLINATIONS_MODEL_PRO=flux-realism
# POLLINATIONS_WIDTH_PRO=1536
# POLLINATIONS_HEIGHT_PRO=1536

# ============================================================
# CAPA POLLINATIONS TEXTO — directo, sin puente Python (PRINCIPAL)
# ============================================================
# Alternativa MAS RAPIDA y ESTABLE para NewserPro. Usa la API de Pollinations
# texto (text.pollinations.ai/openai) directamente desde VerboAI, sin necesidad
# del puente Python.
#
# ORDEN de prioridad en /api/v1/pro-hybrid y /api/v1/chat (NewserPro):
#   1. Pollinations texto ← RAPIDO + GRATIS + ESTABLE
#   2. Puente GLM-4 (g4f, opcional) ← si Pollinations falla
#   3. Pollinations texto ← fallback siempre disponible, sin auth
#
# ============================================================
# MODO ANONIMO (sin registro, default)
# ============================================================
# Modelo: openai-fast (GPT-OSS-20B con razonamiento)
# Solo requiere POLLINATIONS_TEXT_ENABLED_PRO=true (default)
#
# ============================================================
# MODO NECTAR (con registro gratis — desbloquea glm-5.2, gpt-5.6-terra, etc.)
# ============================================================
# 1. Registrarse GRATIS en https://enter.pollinations.ai
# 2. Ir al dashboard → API Keys → Create new key
# 3. Copiar el token (empieza con "sk_...")
# 4. Setear estas variables:
#      POLLINATIONS_TEXT_API_TOKEN=sk_tu_token_aqui
#      POLLINATIONS_TEXT_MODEL=MarcosFRG/glm-5.2
#      POLLINATIONS_TEXT_URL=https://gen.pollinations.ai/v1/chat/completions
#      POLLINATIONS_TEXT_TIMEOUT=120000
#
# Modelos nectar disponibles (con token):
#   - MarcosFRG/glm-5.2 (GLM-5.2, el de la imagen)
#   - gpt-5.6-terra, gpt-5.6-luna, gpt-5.6-sol (1M contexto, reasoning)
#   - gpt-5.4 (1M contexto, reasoning)
#   - glm (1M contexto, reasoning)
#   - deepseek-pro (1M contexto, reasoning)
#   - grok-large (1M contexto, reasoning)
#   - qwen-large (262K, reasoning)
#   - kimi (262K, reasoning)
#   - minimax (524K, reasoning)
#   - Y 100+ más en https://gen.pollinations.ai/v1/models
#
# Activar Pollinations texto (true|false). Default: true
# POLLINATIONS_TEXT_ENABLED_PRO=true

# Modelo a usar.
#   - Anonimo: openai-fast (GPT-OSS-20B con razonamiento) ← default
#   - Nectar:  MarcosFRG/glm-5.2 ← requiere API token
# POLLINATIONS_TEXT_MODEL=openai-fast

# URL de la API.
#   - Anonimo: https://text.pollinations.ai/openai ← default (legacy, solo openai-fast)
#   - Nectar:  https://gen.pollinations.ai/v1/chat/completions ← nueva API con todos los modelos
# POLLINATIONS_TEXT_URL=https://text.pollinations.ai/openai

# Timeout en ms.
#   - Anonimo: 60000 (default)
#   - Nectar:  120000 (modelos reasoning tardan mas)
# POLLINATIONS_TEXT_TIMEOUT=60000

# Referer (ayuda a evitar rate limits). Default: https://verboai.duckdns.org
# POLLINATIONS_TEXT_REFERER=https://verboai.duckdns.org

# Token de Pollinations (OPCIONAL, solo para modelos nectar como glm-5.2)
# Registrarse gratis en https://enter.pollinations.ai → API Keys
# POLLINATIONS_TEXT_API_TOKEN=

# ============================================================
# CAPA OPENROUTER FREE — modelos gratis sin API key
# ============================================================
# Fuente: https://github.com/ClawLabsAI/free-ai-models
# OpenRouter ofrece modelos con tier ":free" que no requieren API key.
# NewserAdmin usa qwen/qwen3-coder:free (Qwen3-Coder-480B-A35B).
#
# Activar OpenRouter free (true|false). Default: true
# OPENROUTER_FREE_ENABLED=true

# Timeout en ms. Default: 60000
# OPENROUTER_FREE_TIMEOUT=60000

# API key opcional de OpenRouter (te da mas rate limit).
# Conseguila gratis en https://openrouter.ai/keys
# Sin esta var, igual funciona (tier free anónimo, 20 req/min)
# OPENROUTER_API_KEY=

# ============================================================
# CAPA GLM-4 (GPT4Free) — opcional, fallback si Pollinations falla
# ============================================================
# Solo se usa si POLLINATIONS_TEXT_ENABLED_PRO=false o si Pollinations texto
# falla. Requiere deployar el puente Python (gpt4free-bridge).
#
# Activar capa GLM-4 (true|false). Default: false
# GPT4FREE_ENABLED_PRO=false

# URL del puente. Puede ser:
#   - Base URL: https://tu-bridge.onrender.com (se le appendea /v1/chat/completions)
#   - URL completa: https://open.bigmodel.cn/api/paas/v4/chat/completions (se usa tal cual)
# GPT4FREE_URL=https://tu-bridge.onrender.com

# Modelo a usar. Default: gpt-4o-mini (recomendado, respeta identidad)
# Alternativas: gpt-4o, Qwen/Qwen3-235B-A22B-Thinking-2507 (si Modelscope lo reactiva)
# GPT4FREE_MODEL=gpt-4o-mini

# API key opcional (Authorization: Bearer ...). Solo si tu puente o la API lo exigen.
# GPT4FREE_API_KEY=

# Timeout en ms. Default: 60000
# GPT4FREE_TIMEOUT=60000

# ============================================================
# Endpoint hibrido dedicado: /api/v1/pro-hybrid
# ============================================================
# Ademas de la integracion automatica en /api/chat y /api/v1/chat (cuando
# GPT4FREE_ENABLED_PRO=true), existe un endpoint explicito que siempre hace
# el flujo Qwen3 (razonamiento) -> GLM-4 (redaccion) con fallback a
# GPT-OSS-120B. Requiere token admin.
#
# Ejemplo de uso:
#   curl -X POST https://tu-app.onrender.com/api/v1/pro-hybrid \
#     -H "Authorization: Bearer verboai-XXXX" \
#     -H "Content-Type: application/json" \
#     -d '{"mensaje":"que es la teoria de cuerdas","forzarGlm":true}'
#
# Respuesta:
#   { ok, respuesta, razonamiento, modeloReal, capaOpenRouter, capaGlm, capaPollinations, ... }

# Judge0 para la herramienta [[CODE::...]] de NewserAdvanced1.5 (ejecucion real de codigo).
# Reemplaza a Piston (dado de baja / whitelist obligatoria desde 2/15/2026).
# Opcion A - RapidAPI (hosteado, mas simple): dejar JUDGE0_API_URL default y poner tu clave
# de https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=tu_clave_de_rapidapi_aqui
# Opcion B - Judge0 CE propia (self-hosted, ej. en un contenedor Docker en Render):
# poner la URL de tu instancia y dejar JUDGE0_API_KEY vacio (no hace falta).
# JUDGE0_API_URL=https://tu-instancia-judge0.onrender.com
