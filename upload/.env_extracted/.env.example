BTATESTERS_KEY=tu_clave_de_api_aqui
# Opcional: también acepta GROQ_API_KEY para compatibilidad
# Podes agregar hasta 5 keys de Groq en total (BTATESTERS_KEY/GROQ_API_KEY + estas 4 mas).
# El servidor las combina y rota automaticamente entre todas cuando una se queda sin cuota
# (HTTP 401/402/403), asi no te quedas sin espacio con una sola cuenta.
# GROQ_API_KEY_2=tu_segunda_clave_de_groq
# GROQ_API_KEY_3=tu_tercera_clave_de_groq
# GROQ_API_KEY_4=tu_cuarta_clave_de_groq
# GROQ_API_KEY_5=tu_quinta_clave_de_groq
GROQ_MODEL=openai/gpt-oss-20b
GROQ_MODEL_VISION=meta-llama/llama-4-scout-17b-16e-instruct
MONGODB_URI=mongodb+srv://marcosmiguel3110_db_user:ZEC8yDEcmUlqzBKw@cluster0.prcmxna.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=biblia_ai
EMAIL_USER=tu_correo_gmail@gmail.com
EMAIL_APP_PASSWORD=tu_contraseña_de_aplicación_de_gmail
RESEND_API_KEY=re_xxxxxxxxxxxxxx
APP_USER=admin
APP_PASS=tu_contraseña_segura
AUTH_SECRET=tu_secreto_aleatorio_largo
# Correos que pueden entrar a la seccion "Clave API" de Settings (separados por coma).
# El admin local siempre tiene acceso aunque no este aca.
EMAILS_AUTORIZADOS_API=marcos.miguel.3110@gmail.com

# Google Custom Search API key para la herramienta [[WEB::...]] de NewserAdvanced.
# Sin esto, la busqueda web no funciona (devuelve error). Los 5 CSE IDs ya estan
# harcodeados en server.js (rotacion automatica si uno se queda sin cuota).
GOOGLE_CSE_API_KEY=tu_api_key_de_google_custom_search

# Modelo de IA para NewserAdvanced (opcional). Default: openai/gpt-oss-120b
# GROQ_MODEL_AVANCED=openai/gpt-oss-120b

# Modelo de IA principal para NewserAdvanced1.5 (opcional). Default: openai/gpt-oss-120b
# GROQ_MODEL_AVANCED=openai/gpt-oss-120b

# Modelo de razonamiento previo para NewserAdvanced1.5, se combina con el de arriba
# (Qwen3-32B hace un paso de razonamiento/planificacion antes de que GPT-OSS-120B
# redacte la respuesta final). Default: qwen/qwen3-32b
# GROQ_MODEL_QWEN=qwen/qwen3-32b

# Judge0 para la herramienta [[CODE::...]] de NewserAdvanced1.5 (ejecucion real de codigo).
# Reemplaza a Piston (dado de baja / whitelist obligatoria desde 2/15/2026).
# Opcion A - RapidAPI (hosteado, mas simple): dejar JUDGE0_API_URL default y poner tu clave
# de https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=tu_clave_de_rapidapi_aqui
# Opcion B - Judge0 CE propia (self-hosted, ej. en un contenedor Docker en Render):
# poner la URL de tu instancia y dejar JUDGE0_API_KEY vacio (no hace falta).
# JUDGE0_API_URL=https://tu-instancia-judge0.onrender.com
