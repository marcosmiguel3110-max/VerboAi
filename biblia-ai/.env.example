BTATESTERS_KEY=tu_clave_de_api_aqui
# Opcional: también acepta GROQ_API_KEY para compatibilidad
# Podes agregar hasta 5 keys de Groq en total (BTATESTERS_KEY/GROQ_API_KEY + estas 4 mas).
# El servidor las combina y rota automaticamente entre todas cuando una se queda sin cuota
# (HTTP 401/402/403), asi no te quedas sin espacio con una sola cuenta.
# GROQ_API_KEY_2=tu_segunda_clave_de_groq
# GROQ_API_KEY_3=tu_tercera_clave_de_groq
# GROQ_API_KEY_4=tu_cuarta_clave_de_groq
# GROQ_API_KEY_5=tu_quinta_clave_de_groq
GROQ_MODEL=openai/gpt-oss-20b
GROQ_MODEL_VISION=meta-llama/llama-4-scout-17b-16e-instruct
MONGODB_URI=mongodb+srv://marcosmiguel3110_db_user:ZEC8yDEcmUlqzBKw@cluster0.prcmxna.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=biblia_ai
EMAIL_USER=tu_correo_gmail@gmail.com
EMAIL_APP_PASSWORD=tu_contraseña_de_aplicación_de_gmail
RESEND_API_KEY=re_xxxxxxxxxxxxxx
APP_USER=admin
APP_PASS=tu_contraseña_segura
AUTH_SECRET=tu_secreto_aleatorio_largo
# Correos que pueden entrar a la seccion "Clave API" de Settings (separados por coma).
# El admin local siempre tiene acceso aunque no este aca.
EMAILS_AUTORIZADOS_API=marcos.miguel.3110@gmail.com

# Google Custom Search API key para la herramienta [[WEB::...]] de NewserAdvanced.
# Sin esto, la busqueda web no funciona (devuelve error). Los 5 CSE IDs ya estan
# harcodeados en server.js (rotacion automatica si uno se queda sin cuota).
GOOGLE_CSE_API_KEY=tu_api_key_de_google_custom_search

# Modelo de IA para NewserAdvanced (opcional). Default: openai/gpt-oss-120b
# GROQ_MODEL_AVANCED=openai/gpt-oss-120b

# Modelo de IA principal para NewserAdvanced1.5 (opcional). Default: openai/gpt-oss-120b
# GROQ_MODEL_AVANCED=openai/gpt-oss-120b

# Modelo de razonamiento previo para NewserAdvanced1.5, se combina con el de arriba
# (Qwen3-32B hace un paso de razonamiento/planificacion antes de que GPT-OSS-120B
# redacte la respuesta final). Default: qwen/qwen3-32b
# GROQ_MODEL_QWEN=qwen/qwen3-32b

# ============================================================
# NewserPro (modelo exclusivo para cuentas administrador)
# ============================================================
# Se habilita solo si el usuario logueado es admin (local:APP_USER o su email
# esta en ADMIN_EMAILS). Tiene el mismo feature set que NewserAdvanced1.5
# (razonamiento previo, CODE, APIDATA, WEB, INVESTIGAR con busqueda web adicional)
# y genera imagenes en alta calidad con el mismo tamaño que NewserAdvanced1.5.

# Modelo de texto principal para NewserPro. Default: openai/gpt-oss-120b
# GROQ_MODEL_PRO=openai/gpt-oss-120b

# Modelo de razonamiento previo para NewserPro. Default: qwen/qwen3-32b
# (NOTA: "Qwen 3.6 27B" no existe en Groq hoy; si lo agregan en el futuro o
# queres usar otro proveedor, pone aca el model ID exacto.)
# GROQ_MODEL_QWEN_PRO=qwen/qwen3-32b

# Config de Pollinations para la generacion de imagenes de NewserPro.
# Defaults: flux-realism, 1536x1536 (mismo tamaño que NewserAdvanced1.5), enhance=true
# POLLINATIONS_MODEL_PRO=flux-realism
# POLLINATIONS_WIDTH_PRO=1536
# POLLINATIONS_HEIGHT_PRO=1536

# ============================================================
# CAPA GLM-4 (GPT4Free) — opcional, solo para NewserPro
# ============================================================
# NewserPro puede usar GLM-4 via un puente externo para la redaccion final.
# Si GLM-4 responde, se usa su texto; si falla, cae automaticamente a
# GPT-OSS-120B (Groq). Hay 2 formas de activarlo:
#
# ============================================================
# OPCION A: API oficial de Zhipu AI (RECOMENDADO, mas confiable)
# ============================================================
# Zhipu AI (creadores de GLM-4) ofrece API con tier gratuito.
# 1. Registrarse en https://open.bigmodel.cn/ y obtener API key.
# 2. Deployar el puente Python de /gpt4free-bridge en Render como servicio
#    separado, seteando USE_ZHIPU=true y ZHIPU_API_KEY=tu_key.
# 3. Apuntar GPT4FREE_URL a ese puente.
#
# ============================================================
# OPCION B: g4f gratis sin registro (menos confiable)
# ============================================================
# Deployar el mismo puente pero sin setear USE_ZHIPU. Usa la libreria g4f
# que scrapea providers publicos. Funciona pero los providers se caen seguido.
#
# ============================================================
# CONFIGuracion en VerboAI (el deploy principal, no el puente)
# ============================================================
# Activar capa GLM-4 en NewserPro (true|false). Default: false
# GPT4FREE_ENABLED_PRO=false

# URL del puente. Puede ser:
#   - Base URL: https://tu-bridge.onrender.com (se le appendea /v1/chat/completions)
#   - URL completa: https://open.bigmodel.cn/api/paas/v4/chat/completions (se usa tal cual)
# GPT4FREE_URL=https://tu-bridge.onrender.com

# Modelo a usar. Default: glm-4
# GPT4FREE_MODEL=glm-4

# API key opcional (Authorization: Bearer ...). Solo si tu puente o la API lo exigen.
# Para Zhipu directo (sin puente): pones tu key de bigmodel.cn aca.
# GPT4FREE_API_KEY=

# Timeout en ms. Default: 60000 (GLM-4 puede tardar bastante)
# GPT4FREE_TIMEOUT=60000

# ============================================================
# Endpoint hibrido dedicado: /api/v1/pro-hybrid
# ============================================================
# Ademas de la integracion automatica en /api/chat y /api/v1/chat (cuando
# GPT4FREE_ENABLED_PRO=true), existe un endpoint explicito que siempre hace
# el flujo Qwen3 (razonamiento) -> GLM-4 (redaccion) con fallback a
# GPT-OSS-120B. Requiere token admin.
#
# Ejemplo de uso:
#   curl -X POST https://tu-app.onrender.com/api/v1/pro-hybrid \
#     -H "Authorization: Bearer verboai-XXXX" \
#     -H "Content-Type: application/json" \
#     -d '{"mensaje":"que es la teoria de cuerdas","forzarGlm":true}'
#
# Respuesta:
#   { ok, respuesta, razonamiento, modeloReal, capaGlm, capaGroq, ... }

# Judge0 para la herramienta [[CODE::...]] de NewserAdvanced1.5 (ejecucion real de codigo).
# Reemplaza a Piston (dado de baja / whitelist obligatoria desde 2/15/2026).
# Opcion A - RapidAPI (hosteado, mas simple): dejar JUDGE0_API_URL default y poner tu clave
# de https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=tu_clave_de_rapidapi_aqui
# Opcion B - Judge0 CE propia (self-hosted, ej. en un contenedor Docker en Render):
# poner la URL de tu instancia y dejar JUDGE0_API_KEY vacio (no hace falta).
# JUDGE0_API_URL=https://tu-instancia-judge0.onrender.com
